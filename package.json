{
  "name": "code-is-crying",
  "displayName": "code-is-crying",
  "publisher": "code-is-crying",
  "description": "Plays a sound whenever your terminal command fails.",
  "version": "0.0.7",
  "icon": "icon.jpeg",
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sound",
    "error",
    "terminal",
    "notification",
    "fun",
    "audio",
    "beep",
    "alert",
    "productivity",
    "meme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/play-sound": "^1.1.2",
    "@types/vscode": "1.93.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
